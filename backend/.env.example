# Template — copy this file to .env and fill in all values.
# NEVER commit the actual .env file (it is in .gitignore).

# ── Database (Supabase) ─────────────────────────────────────────────────────
DB_PASSWORD=your_supabase_db_password

# ── JWT Auth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_that_is_at_least_256_bits_long

# ── Gemini Chatbot ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Paymob Payment Gateway ──────────────────────────────────────────────────
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here

# ── Email / Gmail SMTP (REQUIRED for password reset) ───────────────────────
# Use a Gmail App Password, NOT your regular password.
# Create one at: https://myaccount.google.com/apppasswords (requires 2FA enabled)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# ── Frontend URL (used in password-reset email link) ───────────────────────
FRONTEND_URL=http://localhost:3000
